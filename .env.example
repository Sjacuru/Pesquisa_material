# FILE: .env.example
# MODULE: config — Environment Template
# EPIC: Architecture — Runtime Configuration
# RESPONSIBILITY: Document the local environment variables required by the scaffold.
# EXPORTS: Example configuration keys for local setup.
# DEPENDS_ON: None.
# ACCEPTANCE_CRITERIA:
#   - All runtime-sensitive environment keys used by the scaffold are named.
#   - No real secrets or machine-specific values are included.
# HUMAN_REVIEW: No.

APP_ENV=local
APP_DEBUG=true
DATABASE_URL=postgresql://user:password@localhost:5432/pesquisa_material
STORAGE_ROOT=./var/storage
EXPORT_ROOT=./var/exports
LOG_LEVEL=INFO
TRUST_LOOKUP_TIMEOUT_SECONDS=10
SEARCH_JOB_TIMEOUT_SECONDS=600
